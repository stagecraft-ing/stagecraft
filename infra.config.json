{
  "$schema": "https://encore.dev/schemas/infra.schema.json",
  "metadata": {
    "app_id": "statecraft",
    "env_name": "selfhost",
    "env_type": "production",
    "cloud": "hetzner",
    "base_url": "https://app.statecraft.ing"
  },
  "metrics": {
    "type": "prometheus",
    "remote_write_url": "http://monitoring-prometheus.monitoring:9090/api/v1/write",
    "collection_interval": 60
  },
  "secrets": {
    "JWT_PRIVATE_KEY": { "$env": "JWT_PRIVATE_KEY" },
    "JWT_PUBLIC_KEY": { "$env": "JWT_PUBLIC_KEY" },
    "JWT_REFRESH_PRIVATE_KEY": { "$env": "JWT_REFRESH_PRIVATE_KEY" },
    "JWT_REFRESH_PUBLIC_KEY": { "$env": "JWT_REFRESH_PUBLIC_KEY" },
    "RAUTHY_CLIENT_SECRET": { "$env": "RAUTHY_CLIENT_SECRET" },
    "GITHUB_APP_ID": { "$env": "GITHUB_APP_ID" },
    "GITHUB_APP_PRIVATE_KEY_B64": { "$env": "GITHUB_APP_PRIVATE_KEY_B64" },
    "GITHUB_WEBHOOK_SECRET": { "$env": "GITHUB_WEBHOOK_SECRET" },
    "RAUTHY_API_KEY": { "$env": "RAUTHY_API_KEY" },
    "FLEET_S3_RESTIC_PASSWORD": { "$env": "FLEET_S3_RESTIC_PASSWORD" },
    "FLEET_S3_ACCESS_KEY_ID": { "$env": "FLEET_S3_ACCESS_KEY_ID" },
    "FLEET_S3_SECRET_ACCESS_KEY": { "$env": "FLEET_S3_SECRET_ACCESS_KEY" }
  }
}
