{
  "name": "@statecraft/governance-native",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "spec-spine": { "spec": "008-governance-attestation" },
  "description": "statecraft's governance spine (canonical JSON, attest-ledger record chain, action gate, trust window) as a napi-rs native addon for the Encore.ts governance service (spec 008).",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=24" },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "governance-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test:rust": "cargo test --no-default-features",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.1.5"
  }
}
